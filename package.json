{
  "name": "internet-context-mcp",
  "version": "0.4.2",
  "description": "Read-only MCP server giving AI agents the web as compact, ranked, verified evidence. Local cross-encoder reranker, NLI claim verification, semantic cross-source agreement and contradiction detection. No API keys.",
  "type": "module",
  "bin": {
    "internet-context-mcp": "./dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "ai-agents",
    "claude",
    "anthropic",
    "llm",
    "rag",
    "retrieval",
    "prompt-injection",
    "nli",
    "claim-verification",
    "web-research"
  ],
  "author": "Vivek Varikuti",
  "homepage": "https://github.com/vivekvar-dl/internet-context-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vivekvar-dl/internet-context-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/vivekvar-dl/internet-context-mcp/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "eval:ranking": "tsx scripts/eval-ranking.ts",
    "eval:injection": "tsx scripts/eval-prompt-injection.ts",
    "eval:relevance": "tsx scripts/eval-relevance.ts",
    "stress:real": "tsx scripts/stress-real-sites.ts",
    "start": "node dist/index.js",
    "test": "npm run typecheck && npm run eval:ranking",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^11.10.0",
    "cheerio": "^1.1.2",
    "html-to-text": "^9.0.5",
    "js-tiktoken": "^1.0.21",
    "jsdom": "^27.2.0",
    "@tavily/core": "^0.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "playwright": "^1.59.1"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
