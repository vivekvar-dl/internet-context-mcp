{
  "name": "internet-context-mcp",
  "version": "0.1.0",
  "description": "Clean, compact web context tools for AI agents over MCP.",
  "type": "module",
  "bin": {
    "internet-context-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "eval:ranking": "tsx scripts/eval-ranking.ts",
    "eval:relevance": "tsx scripts/eval-relevance.ts",
    "stress:real": "tsx scripts/stress-real-sites.ts",
    "start": "node dist/index.js",
    "test": "npm run typecheck && npm run eval:ranking",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.1.2",
    "html-to-text": "^9.0.5",
    "jsdom": "^27.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
